        <div class="settings-card">
          <h3>Filter Options</h3>
          <div class="settings-field"><label>Date From</label><input type="date" class="settings-input" id="exportDateFrom"></div>
          <div class="settings-field"><label>Date To</label><input type="date" class="settings-input" id="exportDateTo"></div>
          <div class="settings-field"><label>Department</label>
            <select class="settings-input" id="exportDept">
              <option value="">All Departments</option>
              <option>Civil Engineering</option><option>Computer Science</option><option>Architecture</option><option>Mechanical Engineering</option>
            </select>
          </div>
          <div class="settings-field"><label>Status</label>
            <select class="settings-input" id="exportStatus">
              <option value="">All Statuses</option>
              <option>Present</option><option>Late</option><option>Absent</option><option>Leave</option><option>Online</option><option>Reschedule</option>
            </select>
          </div>
        </div>
        <div class="dash-card"><h3>Report Summary</h3><div class="bar-chart" id="exportBarChart"></div></div>
      </div>
      <div class="dash-grid">
        <div class="dash-card">
          <h3>CSV Export</h3>
          <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">Download filtered records as CSV, compatible with Excel and Google Sheets.</p>
          <button class="export-btn" id="exportCsvAll" style="margin-bottom:10px;width:100%;justify-content:center;"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 9V2M4 6l3 3 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 10v1a1 1 0 001 1h8a1 1 0 001-1v-1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>Download CSV</button>
        </div>
        <div class="dash-card">
          <h3>Excel Export</h3>
          <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">Download as native .xlsx file with formatted columns using SheetJS.</p>
          <button class="export-btn primary-btn" id="exportExcelAll" style="width:100%;justify-content:center;"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 9V2M4 6l3 3 3-3" stroke="#fff" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 10v1a1 1 0 001 1h8a1 1 0 001-1v-1" stroke="#fff" stroke-width="1.3" stroke-linecap="round"/></svg>Download Excel (.xlsx)</button>
        </div>
      </div>
    </div>

    <!-- Settings -->
    <div class="admin-section" id="section-settings">
      <div class="admin-header"><div><h1>Settings</h1><p>System configuration and preferences</p></div></div>
      <div class="settings-grid">
        <div class="settings-card">
          <h3>Attendance Rules</h3>
          <div class="settings-field"><label>Late Threshold (minutes after class start)</label><input type="number" class="settings-input" id="settingLateThreshold" value="15" min="1" max="60"></div>
          <div class="settings-field"><label>Absent Threshold (minutes — no check-in)</label><input type="number" class="settings-input" id="settingAbsentThreshold" value="30" min="15" max="120"></div>
          <div class="settings-field"><label>Work Start Time</label><input type="time" class="settings-input" id="settingWorkStart" value="08:00"></div>
          <div class="settings-field"><label>Work End Time</label><input type="time" class="settings-input" id="settingWorkEnd" value="17:00"></div>
          <button class="save-btn" id="saveSettingsBtn">Save Changes</button>
        </div>
        <div class="settings-card">
          <h3>Check-In Validation Mode</h3>
          <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">Control how lecturers validate their check-in.</p>
          <div class="settings-field">
            <label>Validation Mode</label>
            <select class="settings-input" id="settingValidationMode">
              <option value="none">None (Open Check-In)</option>
              <option value="qr">QR Code Validation</option>
              <option value="gps">GPS Location Validation</option>
            </select>
          </div>
          <div id="qrSettings" style="display:none;">
            <div class="settings-field"><label>QR Code for Main Campus</label><input type="text" class="settings-input" id="settingQrCode" value="ORBYTE-CAMPUS-2025" placeholder="QR code string"></div>
            <div class="settings-field"><label>Generated QR Code</label><div id="adminQrDisplay" style="font-family:monospace;padding:12px;background:var(--bg);border:1px solid var(--border);border-radius:8px;font-size:13px;word-break:break-all;">ORBYTE-CAMPUS-2025</div></div>
          </div>
          <div id="gpsSettings" style="display:none;">
            <div class="settings-field"><label>Campus Latitude</label><input type="text" class="settings-input" id="settingLat" value="-6.285" placeholder="e.g. -6.285"></div>
            <div class="settings-field"><label>Campus Longitude</label><input type="text" class="settings-input" id="settingLng" value="107.1706" placeholder="e.g. 107.1706"></div>
            <div class="settings-field"><label>Allowed Radius (meters)</label><input type="number" class="settings-input" id="settingRadius" value="75" min="10" max="2000"></div>
            <div class="settings-field"><label>Max GPS Accuracy Allowed (meters)</label><input type="number" class="settings-input" id="settingMaxAccuracy" value="150" min="20" max="500" placeholder="150"><span style="font-size:12px;color:var(--text-muted);margin-top:4px;display:block;">Rejects check-in if GPS accuracy is worse than this value (anti-spoof).</span></div>
            <div class="settings-field"><label style="display:flex;align-items:center;gap:10px;cursor:pointer;"><input type="checkbox" id="settingAutoCheckout" checked style="width:15px;height:15px;accent-color:var(--blue);"><span>Auto check-out when leaving campus radius</span></label></div>
          </div>
          <button class="save-btn" id="saveValidationBtn">Save Validation Settings</button>
        </div>
        <div class="settings-card">
          <h3>Notifications</h3>
          <div class="toggle-row"><div class="toggle-info"><p>Late Arrival Alerts</p><span>Notify when lecturer checks in late</span></div><button class="toggle on" id="toggleLateAlert" aria-label="Toggle late arrival alerts" aria-pressed="true"></button></div>
          <div class="toggle-row"><div class="toggle-info"><p>Absence Alerts</p><span>Notify when no check-in by threshold</span></div><button class="toggle on" id="toggleAbsenceAlert" aria-label="Toggle absence alerts" aria-pressed="true"></button></div>
          <div class="toggle-row"><div class="toggle-info"><p>Leave Request Notifications</p><span>Notify students when leave is submitted</span></div><button class="toggle on" id="toggleLeaveAlert" aria-label="Toggle leave alerts" aria-pressed="true"></button></div>
          <div class="toggle-row"><div class="toggle-info"><p>Weekend Tracking</p><span>Track attendance on weekends</span></div><button class="toggle" id="toggleWeekend" aria-label="Toggle weekend tracking" aria-pressed="false"></button></div>
        </div>
        <div class="settings-card">
          <h3>Data Management</h3>
          <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">Manage your attendance data and system records.</p>
          <button class="export-btn" style="width:100%;justify-content:center;margin-bottom:10px;" id="clearDataBtn">Clear All localStorage Data</button>
          <button class="export-btn" style="width:100%;justify-content:center;" id="rebuildDataBtn">Rebuild Demo Dataset</button>
        </div>
      </div>
    </div>
  </main>
</div>
</div>

<!-- ======= STUDENT VIEW ======= -->
<div id="studentView" class="view">
<div class="student-wrap">
  <nav class="student-topnav topnav" aria-label="Student navigation">
    <a class="nav-logo" href="#" aria-label="UniAttend Home">
      <div class="nav-logo-icon"><svg viewBox="0 0 16 16" fill="none"><path d="M8 2L14 5V11L8 14L2 11V5L8 2Z" stroke="#fff" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 2V14" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/><path d="M2 5L14 11" stroke="#fff" stroke-width="1.2" stroke-linecap="round" opacity=".5"/></svg></div>
      ORBYTE
    </a>
    <div class="nav-links">
      <button class="nav-link active" data-stutab="dashboard">Dashboard</button>
      <button class="nav-link" data-stutab="schedule">Schedule</button>
      <button class="nav-link" data-stutab="profile">Profile</button>
    </div>
    <div class="nav-user-wrap">
      <button class="nav-notif" id="stuNotifBtn" aria-label="Notifications" title="Notifications">
        <svg viewBox="0 0 16 16" fill="none"><path d="M8 2a5 5 0 015 5v2.5l1 1.5H2l1-1.5V7a5 5 0 015-5z" stroke="currentColor" stroke-width="1.3"/><path d="M6.5 13a1.5 1.5 0 003 0" stroke="currentColor" stroke-width="1.3"/></svg>
        <span class="nav-notif-dot" id="stuNotifDot" style="display:none;"></span>
        <span class="nav-notif-count" id="stuNotifCount" style="display:none;"></span>
      </button>
      <div class="nav-user-info">
        <div class="nav-user-name" id="stuNavName">Student</div>
        <div class="nav-user-role">Student</div>
      </div>
      <div class="nav-avatar" id="stuNavAvatar" style="background:linear-gradient(135deg,#0891b2,#0369a1)">S</div>
      <button class="logout-btn" id="stuLogoutBtn" aria-label="Logout">
        <svg viewBox="0 0 14 14" fill="none"><path d="M9.5 7H3M6 4.5L3 7l3 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 2h3.5A1.5 1.5 0 0112 3.5v7A1.5 1.5 0 0110.5 12H7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        Logout
      </button>
    </div>
  </nav>

  <main class="stu-main">
    <!-- Dashboard Tab -->
    <div class="stu-page active" id="stutab-dashboard">
      <div class="stu-welcome">
        <div class="stu-welcome-inner">
          <h1>Good morning, <span id="stuGreetName">Student</span> 👋</h1>
          <p id="stuDateStr">Loading...</p>
          <div class="stu-welcome-stats">
            <div class="stu-welcome-stat"><div class="sw-val" id="stuWelTotal">0</div><div class="sw-lbl">Total Classes</div></div>
            <div class="stu-welcome-stat"><div class="sw-val" id="stuWelPresent">0</div><div class="sw-lbl">Attended</div></div>
            <div class="stu-welcome-stat"><div class="sw-val" id="stuWelRate">0%</div><div class="sw-lbl">Attendance Rate</div></div>
          </div>
        </div>
        <!-- Notifications auto-enabled on login -->
        <div style="display:none;" id="stuNotifEnableWrap">
          <button class="checkin-btn primary" id="enableNotifBtn" style="gap:8px;display:none;"></button>
          <span id="notifStatusLabel" style="font-size:12px;color:rgba(255,255,255,.65);margin-left:10px;"></span>
        </div>
      </div>

      <div class="stu-summary-grid">
        <div class="stu-sum-card"><div class="stu-sum-icon ic-present"><svg viewBox="0 0 16 16" fill="none"><path d="M3 8l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div><div class="stu-sum-val" id="stuSumPresent">24</div><div class="stu-sum-lbl">Present</div></div></div>
        <div class="stu-sum-card"><div class="stu-sum-icon ic-absent"><svg viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></div><div><div class="stu-sum-val" id="stuSumAbsent">3</div><div class="stu-sum-lbl">Absent</div></div></div>
        <div class="stu-sum-card"><div class="stu-sum-icon ic-late"><svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M8 5v3.5l2 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></div><div><div class="stu-sum-val" id="stuSumLate">2</div><div class="stu-sum-lbl">Late</div></div></div>
        <div class="stu-sum-card"><div class="stu-sum-icon ic-rate"><svg viewBox="0 0 16 16" fill="none"><path d="M2 12l4-4 3 2 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div><div class="stu-sum-val" id="stuSumRate">83%</div><div class="stu-sum-lbl">Rate</div></div></div>
      </div>

      <div class="section-card">
        <div class="section-header">
          <h3>Today's Schedule <span id="stuLiveIndicator" class="live-badge">● LIVE</span></h3>
          <span id="stuTodayCount" style="font-size:13px;color:var(--text-muted);">Loading...</span>
        </div>
        <div id="stuTodaySchedule" style="padding:16px 24px 24px;"></div>
      </div>

      <!-- Recent notifications preview -->
      <div class="section-card" id="stuRecentNotifsCard">
        <div class="section-header"><h3>Recent Notifications</h3><button class="link-btn" id="viewAllNotifsBtn">View all →</button></div>
        <div id="stuRecentNotifs" style="padding:0 24px 16px;"></div>
      </div>
    </div>

    <!-- Schedule Tab -->
    <div class="stu-page" id="stutab-schedule">
      <div class="page-header"><h1>Weekly Schedule</h1><p>Your full class timetable for this semester</p></div>
      <div class="section-card">
        <div class="section-header"><h3>Timetable — Week View</h3><span style="font-size:13px;color:var(--text-muted);">Semester 2, 2024/2025</span></div>
        <div class="week-table-wrap" style="padding:0 0 8px;">
          <table class="week-table" style="width:100%;border-collapse:collapse;">
            <thead><tr>
              <th style="width:90px;padding:12px 16px;text-align:left;">Time</th>
              <th style="padding:12px 8px;">Mon</th><th style="padding:12px 8px;">Tue</th><th style="padding:12px 8px;">Wed</th><th style="padding:12px 8px;">Thu</th><th style="padding:12px 8px;">Fri</th>
            </tr></thead>
            <tbody id="stuWeekTable"></tbody>
          </table>
        </div>
      </div>
      <div class="section-card" style="margin-top:16px;">
        <div class="section-header"><h3>Attendance History</h3><span style="font-size:13px;color:var(--text-muted);">Last 30 days</span></div>
        <table><thead><tr><th>Date</th><th>Subject</th><th>Lecturer</th><th>Time</th><th>Lecturer Status</th></tr></thead><tbody id="stuHistoryBody"></tbody></table>
      </div>
    </div>

    <!-- Profile Tab -->
    <div class="stu-page" id="stutab-profile">
      <div class="page-header"><h1>My Profile</h1><p>Your personal and academic information</p></div>
      <div class="stu-profile-card">
        <div class="stu-profile-header">
          <div class="stu-avatar-wrap">
            <div class="stu-avatar" id="stuProfileAvatar">S</div>
            <div class="stu-avatar-edit" title="Change photo"><svg viewBox="0 0 12 12" fill="none"><path d="M8.5 1.5l2 2L4 10l-2.5.5.5-2.5L8.5 1.5z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg></div>
          </div>
          <div>
            <div class="stu-profile-name" id="stuProfileName">Aiman Danial</div>
            <div class="stu-profile-sub" id="stuProfileSub">Computer Science · Year 2</div>
            <div class="stu-profile-tags">
              <span class="stu-tag"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M5.5 1L9.5 3V7L5.5 9.5L1.5 7V3L5.5 1Z" stroke="currentColor" stroke-width="1.1"/></svg>Active Student</span>
              <span class="stu-tag" style="background:var(--blue-light);color:var(--blue);border-color:var(--blue-mid);">Dean's List</span>
            </div>
          </div>
        </div>
        <div class="stu-profile-grid">
          <div class="stu-profile-field"><label>Student ID</label><span class="mono" id="stuProfileId">STU-0001</span></div>
          <div class="stu-profile-field"><label>Email</label><span id="stuProfileEmail"><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="ed8c84808c83c3898c83848c81ad9e999889888399c3888998c38094">[email&#160;protected]</a></span></div>
          <div class="stu-profile-field"><label>Programme</label><span>Bachelor of Computer Science</span></div>
          <div class="stu-profile-field"><label>Faculty</label><span>Faculty of Computing</span></div>
          <div class="stu-profile-field"><label>Semester</label><span>Semester 2, 2024/2025</span></div>
          <div class="stu-profile-field"><label>Class Group</label><span>CS-2B</span></div>
          <div class="stu-profile-field"><label>Advisor</label><span>Dr. Hafizuddin Zain</span></div>
          <div class="stu-profile-field"><label>Enrolled</label><span>September 2023</span></div>
        </div>
        <button class="stu-edit-btn" onclick="showToast('Edit profile coming soon', 'warning')"><svg viewBox="0 0 14 14" fill="none"><path d="M9.5 1.5l3 3L5 12H2v-3L9.5 1.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>Edit Profile</button>
      </div>
      <div class="section-card">
        <div class="section-header"><h3>Attendance Progress by Subject</h3></div>
        <div style="padding:16px 24px 24px;" id="stuSubjectProgress"><!-- populated by JS --></div>
      </div>
    </div>
  </main>
</div>
</div>

<!-- SheetJS Local - no tracking/CORS issues -->
<script src="xlsx.min.js"></script>
<script src="script.js" defer></script>
</body>
</html>