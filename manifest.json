<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UniAttend — Attendance System</title>
<meta name="theme-color" content="#1D4ED8">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="style.css">
</head>
<body>

<!-- ======= LOGIN PAGE ======= -->
<div id="loginPage" class="active" role="main">
  <div class="login-bg-blob login-bg-blob-1" aria-hidden="true"></div>
  <div class="login-bg-blob login-bg-blob-2" aria-hidden="true"></div>
  <div class="login-bg-blob login-bg-blob-3" aria-hidden="true"></div>
  <div class="login-split">
    <div class="login-brand" aria-hidden="true">
      <div class="brand-top">
        <div class="brand-logo">
          <div class="brand-logo-icon">
            <svg viewBox="0 0 16 16" fill="none"><path d="M8 2L14 5V11L8 14L2 11V5L8 2Z" stroke="#fff" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 2V14" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/><path d="M2 5L14 11" stroke="#fff" stroke-width="1.2" stroke-linecap="round" opacity=".5"/><path d="M14 5L2 11" stroke="#fff" stroke-width="1.2" stroke-linecap="round" opacity=".5"/></svg>
          </div>
          ORBYTE
        </div>
        <div class="brand-tagline">Smart Attendance<br>for <span>Modern Campuses</span></div>
        <div class="brand-desc">Track lecturer attendance in real-time across all departments with smart insights and instant reporting.</div>
      </div>
      <div class="brand-features">
        <div class="brand-feat"><div class="brand-feat-icon"><svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/><path d="M7 4v3l2 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></div>Real-time check-in tracking</div>
        <div class="brand-feat"><div class="brand-feat-icon"><svg viewBox="0 0 14 14" fill="none"><rect x="2" y="2" width="4" height="4" rx=".8" stroke="currentColor" stroke-width="1.3"/><rect x="8" y="2" width="4" height="4" rx=".8" stroke="currentColor" stroke-width="1.3"/><rect x="2" y="8" width="4" height="4" rx=".8" stroke="currentColor" stroke-width="1.3"/><rect x="8" y="8" width="4" height="4" rx=".8" stroke="currentColor" stroke-width="1.3"/></svg></div>Admin dashboard with KPIs</div>
        <div class="brand-feat"><div class="brand-feat-icon"><svg viewBox="0 0 14 14" fill="none"><path d="M4 2h5l3 3v7H4V2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M9 2v3h3" stroke="currentColor" stroke-width="1.3"/><path d="M5.5 7.5h3M5.5 9.5h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></div>CSV &amp; Excel export reports</div>
        <div class="brand-feat"><div class="brand-feat-icon"><svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="5" r="2.5" stroke="currentColor" stroke-width="1.3"/><path d="M2 12c0-2.21 2.239-4 5-4s5 1.79 5 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></div>Multi-role secure access</div>
      </div>
      <div class="brand-bottom">© 2025 Orbyte UniAttend · Demo System</div>
    </div>
    <div class="login-form-panel">
      <div class="login-form-header">
        <div class="login-form-title">Login to Attendance System</div>
        <div class="login-form-sub">Sign in with your staff credentials to continue.</div>
      </div>
      <form id="loginForm" novalidate autocomplete="on">
        <fieldset style="border:none;margin-bottom:28px;" aria-label="Select your role">
          <legend style="font-size:13px;font-weight:500;color:var(--text-muted);margin-bottom:8px;">I am a</legend>
          <div class="role-switcher" role="radiogroup" aria-label="Role selection">
            <button type="button" class="role-btn active" id="roleLecturerBtn" aria-pressed="true" aria-label="Login as Lecturer">
              <svg viewBox="0 0 15 15" fill="none"><circle cx="7.5" cy="4.5" r="2.5" stroke="currentColor" stroke-width="1.3"/><path d="M2 12.5c0-2.21 2.462-4 5.5-4s5.5 1.79 5.5 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              Lecturer
            </button>
            <button type="button" class="role-btn" id="roleAdminBtn" aria-pressed="false" aria-label="Login as Admin">
              <svg viewBox="0 0 15 15" fill="none"><path d="M7.5 1.5l1.2 3.6L12.5 5l-2.7 2.4.9 3.6-3.2-1.8L4.3 11l.9-3.6L2.5 5l3.8-.9L7.5 1.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
              Admin
            </button>
            <button type="button" class="role-btn role-student" id="roleStudentBtn" aria-pressed="false" aria-label="Login as Student">
              <svg viewBox="0 0 15 15" fill="none"><path d="M7.5 1L14 4.5l-6.5 3L1 4.5 7.5 1z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M1 4.5v5.5M14 4.5v5.5M7.5 8l-5 2.5v1.5l5 2.5 5-2.5v-1.5L7.5 8z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
              Student
            </button>
          </div>
        </fieldset>
        <div class="login-error" id="loginError" role="alert" aria-live="assertive">
          <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3"/><path d="M8 5v3.5M8 10.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span id="loginErrorMsg">Invalid credentials. Please try again.</span>
        </div>
        <div class="login-field">
          <label for="loginId" id="loginIdLabel">Email</label>
          <div class="login-input-wrap">
            <span class="login-input-icon"><svg viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M2 5l6 4 6-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
            <input type="email" id="loginId" name="username" class="login-input" autocomplete="email" placeholder="e.g. ahmad.hafiz@president.ac.id" aria-labelledby="loginIdLabel" aria-required="true" aria-describedby="loginIdHint">
          </div>
          <span id="loginIdHint" style="display:none"></span>
        </div>
        <div class="login-field">
          <label for="loginPw">Password</label>
          <div class="login-input-wrap">
            <span class="login-input-icon"><svg viewBox="0 0 16 16" fill="none"><rect x="4" y="7" width="8" height="6" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M5.5 7V5a2.5 2.5 0 015 0v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="8" cy="10" r="1" fill="currentColor"/></svg></span>
            <input type="password" id="loginPw" name="password" class="login-input" autocomplete="current-password" placeholder="Enter your password" aria-label="Password" aria-required="true">
            <button type="button" class="pw-toggle" id="pwToggle" aria-label="Show password" aria-pressed="false">
              <svg id="eyeIcon" viewBox="0 0 16 16" fill="none"><ellipse cx="8" cy="8" rx="6" ry="4" stroke="currentColor" stroke-width="1.3"/><circle cx="8" cy="8" r="1.5" stroke="currentColor" stroke-width="1.3"/></svg>
            </button>
          </div>
        </div>
        <div class="login-meta">
          <label class="remember-wrap"><input type="checkbox" id="rememberMe" aria-label="Remember me"><span>Remember me</span></label>
          <button type="button" class="forgot-link" id="forgotBtn">Forgot password?</button>
        </div>
        <button type="submit" class="login-btn" id="loginBtn">
          <span class="btn-text">Sign In</span>
          <span class="btn-spinner" aria-hidden="true"></span>
        </button>
        <div class="demo-hint" aria-label="Demo credentials hint">
          <strong>Demo credentials —</strong>
          <div class="demo-hint-row" style="margin-top:4px;"><span>Lecturer:</span><button type="button" class="demo-hint-fill" data-id="ahmad.hafiz@president.ac.id" data-email="ahmad.hafiz@president.ac.id" data-pw="ahmad123" data-role="lecturer">ahmad.hafiz@president.ac.id / ahmad123</button></div>
          <div class="demo-hint-row"><span>Admin:</span><button type="button" class="demo-hint-fill" data-id="admin@president.ac.id" data-email="admin@president.ac.id" data-pw="admin123" data-role="admin">admin@president.ac.id / admin123</button></div>
          <div class="demo-hint-row student-row"><span>Student:</span><button type="button" class="demo-hint-fill" data-id="aiman.danial@president.ac.id" data-email="aiman.danial@president.ac.id" data-pw="aiman123" data-role="student">aiman.danial@president.ac.id / aiman123</button></div>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Forgot Password Modal -->
<div class="forgot-modal-backdrop" id="forgotBackdrop" role="dialog" aria-modal="true" aria-labelledby="forgotTitle">
  <div class="forgot-modal">
    <div class="forgot-modal-icon" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" stroke="var(--blue)" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0110 0v4" stroke="var(--blue)" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="16" r="1.5" fill="var(--blue)"/></svg>
    </div>
    <h3 id="forgotTitle">Reset your password</h3>
    <p>This is a demo system. In a real deployment, a reset link would be emailed to your registered address.<br><br>For now, please use the demo credentials shown on the login form.</p>
    <div class="forgot-modal-actions">
      <button class="forgot-modal-cancel" id="forgotCancel">Cancel</button>
      <button class="forgot-modal-send" id="forgotOk">Got it</button>
    </div>
  </div>
</div>

<!-- ======= SKELETON LOADER ======= -->
<div class="skeleton-overlay" id="skeletonOverlay" role="status" aria-live="polite">
  <div class="skeleton-spinner"></div>
  <p class="skeleton-text" id="skeletonText">Loading…</p>
</div>

<!-- ======= TOAST ======= -->
<div class="toast" id="toast" role="alert" aria-live="assertive">
  <div class="toast-icon">
    <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
  <span id="toastMsg">Action completed</span>
</div>

<!-- ======= RECORD DETAIL MODAL ======= -->
<div class="modal-backdrop" id="modalBackdrop" role="dialog" aria-modal="true" aria-labelledby="modalTitleEl">
  <div class="modal" id="modalEl">
    <div class="modal-accent"></div>
    <div class="modal-header">
      <div>
        <div class="modal-title" id="modalTitleEl"></div>
        <div class="modal-subtitle" id="modalSubtitle"></div>
      </div>
      <button class="modal-close" id="modalCloseBtn" aria-label="Close dialog">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
    <div class="modal-body" id="modalBody"></div>
  </div>
</div>

<!-- ======= LEAVE REQUEST MODAL (Lecturer) ======= -->
<div class="modal-backdrop" id="leaveModalBackdrop" role="dialog" aria-modal="true" aria-labelledby="leaveModalTitle">
  <div class="modal" id="leaveModalEl" style="max-width:520px;">
    <div class="modal-accent" style="background:var(--warning)"></div>
    <div class="modal-header">
      <div>
        <div class="modal-title" id="leaveModalTitle">Request Leave / Report Delay</div>
        <div class="modal-subtitle">Submit your leave or delay report for today</div>
      </div>
      <button class="modal-close" id="leaveModalClose" aria-label="Close">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <form id="leaveForm" novalidate>
        <div class="login-field">
          <label>Request Type</label>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <label class="leave-type-btn"><input type="radio" name="leaveType" value="Late" checked> <span>🕐 Late Arrival</span></label>
            <label class="leave-type-btn"><input type="radio" name="leaveType" value="Absent"> <span>❌ Absent</span></label>
            <label class="leave-type-btn"><input type="radio" name="leaveType" value="Online"> <span>💻 Online Class</span></label>
            <label class="leave-type-btn"><input type="radio" name="leaveType" value="Reschedule"> <span>📅 Reschedule</span></label>
          </div>
        </div>
        <div class="login-field">
          <label for="leaveClass">Affected Class</label>
          <select id="leaveClass" class="login-input" style="padding-left:14px;">
            <option value="">Select class...</option>
          </select>
        </div>
        <div class="login-field">
          <label for="leaveDate">Date</label>
          <input type="date" id="leaveDate" class="login-input" style="padding-left:14px;">
        </div>
        <div class="login-field" id="rescheduleFields" style="display:none;">
          <label>Reschedule To</label>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div><label for="newDate" style="font-size:12px;color:var(--text-muted);">New Date</label><input type="date" id="newDate" class="login-input" style="padding-left:14px;margin-top:4px;"></div>
            <div><label for="newTime" style="font-size:12px;color:var(--text-muted);">New Time</label><input type="time" id="newTime" class="login-input" style="padding-left:14px;margin-top:4px;"></div>
          </div>
          <div style="margin-top:8px;"><label for="newRoom" style="font-size:12px;color:var(--text-muted);">New Room</label><input type="text" id="newRoom" class="login-input" placeholder="e.g. Block B-101" style="padding-left:14px;margin-top:4px;"></div>
        </div>
        <div class="login-field">
          <label for="leaveReason">Reason</label>
          <textarea id="leaveReason" class="login-input" rows="3" placeholder="Provide a brief explanation..." style="padding-left:14px;resize:vertical;"></textarea>
        </div>
        <div class="login-field">
          <label for="leaveProof">Proof Document (optional)</label>
          <input type="file" id="leaveProof" accept="image/*,.pdf" class="login-input" style="padding-left:14px;">
          <span style="font-size:12px;color:var(--text-muted);">Image or PDF. Will be stored locally.</span>
        </div>
        <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:16px;">
          <button type="button" class="export-btn" id="leaveModalCancelBtn">Cancel</button>
          <button type="submit" class="login-btn" style="width:auto;padding:10px 24px;">Submit Request</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ======= CHECK-IN VALIDATION MODAL (Lecturer) ======= -->
<div class="modal-backdrop" id="checkinValidateBackdrop" role="dialog" aria-modal="true" aria-labelledby="checkinValidateTitle">
  <div class="modal" id="checkinValidateEl" style="max-width:440px;">
    <div class="modal-accent"></div>
    <div class="modal-header">
      <div>
        <div class="modal-title" id="checkinValidateTitle">Validate Check-In</div>
        <div class="modal-subtitle" id="checkinValidateSub">Enter the QR code or confirm your location</div>
      </div>
      <button class="modal-close" id="checkinValidateClose" aria-label="Close">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
    <div class="modal-body" id="checkinValidateBody"></div>
  </div>
</div>

<!-- ======= NOTIFICATION PANEL ======= -->
<div class="notif-panel-backdrop" id="notifPanelBackdrop" aria-hidden="true"></div>
<aside class="notif-panel" id="notifPanel" role="complementary" aria-label="Notifications">
  <div class="notif-panel-header">
    <h3>Notifications</h3>
    <div style="display:flex;gap:8px;align-items:center;">
      <button class="link-btn" id="markAllReadBtn" style="font-size:12px;">Mark all read</button>
      <button class="modal-close" id="notifPanelClose" aria-label="Close notifications">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
  <div class="notif-panel-body" id="notifPanelBody"></div>
</aside>


<!-- ======= LECTURER VIEW ======= -->
<div id="lecturerView" class="view">
<div class="lecturer-wrap">
  <nav class="topnav" aria-label="Lecturer navigation">
    <a class="nav-logo" href="#" aria-label="UniAttend Home">
      <div class="nav-logo-icon">
        <svg viewBox="0 0 16 16" fill="none"><path d="M8 2L14 5V11L8 14L2 11V5L8 2Z" stroke="#fff" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 2V14" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/><path d="M2 5L14 11" stroke="#fff" stroke-width="1.2" stroke-linecap="round" opacity=".5"/><path d="M14 5L2 11" stroke="#fff" stroke-width="1.2" stroke-linecap="round" opacity=".5"/></svg>
      </div>
      ORBYTE
    </a>
    <div class="nav-links">
      <button class="nav-link active" data-tab="attendance">Attendance</button>
      <button class="nav-link" data-tab="history">History</button>
      <button class="nav-link" data-tab="profile">Profile</button>
    </div>
    <div class="nav-user-wrap">
      <div class="nav-user-info">
        <div class="nav-user-name" id="lecNavName">Ahmad Hafiz</div>
        <div class="nav-user-role">Lecturer</div>
      </div>
      <div class="nav-avatar" id="lecNavAvatar" aria-hidden="true">AH</div>
      <button class="logout-btn" id="lecLogoutBtn" aria-label="Logout from lecturer account">
        <svg viewBox="0 0 14 14" fill="none"><path d="M9.5 7H3M6 4.5L3 7l3 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 2h3.5A1.5 1.5 0 0112 3.5v7A1.5 1.5 0 0110.5 12H7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        Logout
      </button>
    </div>
  </nav>

  <main class="lec-main">
    <!-- Attendance Tab -->
    <div class="lec-page active" id="tab-attendance">
      <div class="page-header">
        <h1>Good morning, <span id="lecGreetName">Ahmad</span> 👋 <span class="live-clock" id="liveClock"></span></h1>
        <p id="todayDateStr">Loading date…</p>
      </div>
      <div class="daily-summary">
        <div class="ds-card"><div class="ds-icon ic-classes"><svg viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M11 2v2M5 2v2M2 7h12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></div><div><div class="ds-val" id="lecDailyClasses">3</div><div class="ds-lbl">Classes Today</div></div></div>
        <div class="ds-card"><div class="ds-icon ic-hours"><svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M8 5v3l2 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></div><div><div class="ds-val" id="lecWorkedHours">—</div><div class="ds-lbl">Hours Worked</div></div></div>
        <div class="ds-card"><div class="ds-icon ic-rate"><svg viewBox="0 0 16 16" fill="none"><path d="M2 11l4-4 3 2 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div><div class="ds-val" id="lecAttendRate">—</div><div class="ds-lbl">Attendance Rate</div></div></div>
      </div>

      <!-- Pending leave request banner -->
      <div id="pendingLeaveAlert" class="leave-alert" style="display:none;"></div>

      <div class="status-card" id="statusCard">
        <div class="status-row">
          <div class="status-info">
            <h2>Current status</h2>
            <div class="status-badge out" id="statusBadge">
              <span class="status-dot" id="statusDot"></span>
              <span id="statusText">Checked Out</span>
            </div>
            <p class="status-meta" id="lastAction">Last action: Yesterday at 5:02 PM</p>
          </div>
          <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <button class="checkin-btn primary" id="checkInBtn" aria-label="Check in">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 3v6l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/></svg>
              Check In
            </button>
            <button class="checkin-btn checkout" id="checkOutBtn" disabled aria-label="Check out">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M6 9h6M9 6l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/></svg>
              Check Out
            </button>
          </div>
        </div>
        <div class="details-row">
          <div class="detail-item"><label>Department</label><span id="lecDeptLabel">Civil Engineering</span></div>
          <div class="detail-item"><label>Staff ID</label><span class="mono" id="lecIdLabel">CE-2041</span></div>
          <div class="detail-item"><label>Location</label><span>Building A, Floor 3</span></div>
          <div class="detail-item"><label>Today's Schedule</label><span>08:00 – 17:00</span></div>
          <div class="detail-item"><label>Check In</label><span class="mono" id="detailCheckIn">—</span></div>
          <div class="detail-item"><label>Check Out</label><span class="mono" id="detailCheckOut">—</span></div>
        </div>
      </div>

      <!-- GPS Auto Check-In Panel -->
      <div class="gps-panel" id="gpsPanelCard">
        <div class="gps-panel-header">
          <div class="gps-panel-title">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.3"/><path d="M8 1v2M8 13v2M1 8h2M13 8h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="8" cy="8" r="1" fill="currentColor"/></svg>
            GPS Auto Check-In
          </div>
          <span id="gpsPanelDist" class="gps-dist-badge" style="display:none;"></span>
        </div>
        <div class="gps-panel-body">
          <div id="gpsPanelStatus" class="gps-status-line">
